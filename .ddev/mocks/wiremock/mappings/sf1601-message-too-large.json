{
  "request": {
    "method": "POST",
    "urlPath": "/service/KombiPostAfsend_1/kombi",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.meta.force_too_large"
      }
    ]
  },
  "response": {
    "status": 413,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "rejected",
      "error_code": "MESSAGE_TOO_LARGE",
      "message": "Message size exceeds SF1601 maximum of 10 MB"
    }
  }
}
