<?php

/**
 * @file
 * ÅbenForms Core module.
 *
 * Provides foundation services for Danish government integrations:
 * - ServiceplatformenClient: SOAP client for SF1500 services
 * - EncryptionService: Field-level AES-256 encryption for sensitive data
 * - AuditLogger: GDPR-compliant audit logging for CPR/CVR lookups
 * - TenantResolver: Multi-tenant domain detection
 * - AabenformsDashboardSection plugin manager (admin dashboard).
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Url;
use Drupal\user\Entity\User;

/**
 * Implements hook_help().
 */
function aabenforms_core_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.aabenforms_core':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('ÅbenForms Core provides foundation services for Danish government service integrations. This module is required by all other ÅbenForms modules.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<dl>';
      $output .= '<dt>' . t('Serviceplatformen Integration') . '</dt>';
      $output .= '<dd>' . t('SOAP client for connecting to Danish government services (SF1520 CPR lookup, SF1530 CVR lookup, SF1601 Digital Post).') . '</dd>';
      $output .= '<dt>' . t('Field Encryption') . '</dt>';
      $output .= '<dd>' . t('AES-256 encryption for sensitive personal data (CPR numbers) to ensure GDPR compliance.') . '</dd>';
      $output .= '<dt>' . t('Audit Logging') . '</dt>';
      $output .= '<dd>' . t('Comprehensive logging of all sensitive data access for compliance and security auditing.') . '</dd>';
      $output .= '<dt>' . t('Multi-Tenancy') . '</dt>';
      $output .= '<dd>' . t('Integration with Domain module for tenant-specific configuration and data isolation.') . '</dd>';
      $output .= '<dt>' . t('Admin Dashboard') . '</dt>';
      $output .= '<dd>' . t('Unified entry point at <a href=":url">/admin/aabenforms</a> showing each module\'s state, recent activity, and quick actions.', [
        ':url' => Url::fromRoute('aabenforms_core.dashboard')->toString(),
      ]) . '</dd>';
      $output .= '</dl>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function aabenforms_core_theme(): array {
  return [
    'aabenforms_dashboard' => [
      'variables' => [
        'header' => [],
        'quick_actions' => [],
        'sections' => [],
        'activity' => NULL,
      ],
    ],
    'aabenforms_dashboard_section_card' => [
      'variables' => [
        'section_id' => '',
        'label' => '',
        'status_badge' => NULL,
        'hero_metric' => NULL,
        'secondary_metrics' => [],
        'main_link' => [],
      ],
    ],
    'aabenforms_dashboard_landing' => [
      'variables' => [
        'title' => '',
        'tagline' => '',
        'frontend_url' => '',
        'login_url' => '',
        'docs_url' => '',
      ],
    ],
    'aabenforms_dashboard_activity' => [
      'variables' => [
        'filter' => 'errors',
        'filters' => [],
        'rows' => [],
        'pivoted' => FALSE,
        'empty_message' => '',
      ],
    ],
  ];
}

/**
 * Implements hook_form_FORM_ID_alter() for user_login_form.
 *
 * The standard /user/login form sets $form_state->setRedirect('user.page')
 * as its default landing target (which resolves to /user/{uid}). We want
 * users with the dashboard permission to land on /admin/aabenforms
 * instead. Inject our own submit handler that runs AFTER Drupal core's
 * default and overrides the redirect when applicable.
 *
 * Guards: skip if the user supplied an explicit ?destination=
 * (RedirectResponseSubscriber will honor that anyway).
 */
function aabenforms_core_form_user_login_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['#submit'][] = 'aabenforms_core_user_login_form_redirect';
}

/**
 * Submit handler for user_login_form. Sends admins to /admin/aabenforms.
 */
function aabenforms_core_user_login_form_redirect(array &$form, FormStateInterface $form_state): void {
  if (\Drupal::request()->query->has('destination')) {
    return;
  }
  $uid = (int) $form_state->get('uid');
  if (!$uid) {
    return;
  }
  $account = User::load($uid);
  if ($account && $account->hasPermission('access aabenforms admin')) {
    $form_state->setRedirect('aabenforms_core.dashboard');
  }
}

/**
 * Implements hook_user_login().
 *
 * Covers the non-form login paths: password-reset URL, SSO callbacks,
 * Drush uli, etc. The standard /user/login flow is handled by the
 * form-alter above (more reliable than nudging request->query).
 *
 * Guards: skip if a destination is already set, skip on the password-
 * reset route's own form (it has its own redirect logic), only act
 * when the account has access aabenforms admin.
 */
function aabenforms_core_user_login($account): void {
  if (!$account->hasPermission('access aabenforms admin')) {
    return;
  }
  $request = \Drupal::request();
  if ($request->query->has('destination')) {
    return;
  }
  $route_name = \Drupal::routeMatch()->getRouteName();
  if (in_array($route_name, ['user.reset', 'user.reset.login', 'user.reset.form'], TRUE)) {
    return;
  }
  $request->query->set('destination', '/admin/aabenforms');
}

/**
 * Implements hook_cron().
 *
 * Purges audit log entries older than the configured retention window.
 * Default is 1825 days (5 years) to align with GDPR audit-retention
 * expectations. Set aabenforms_core.settings audit.retention_days to 0 to
 * disable purging, or raise the batch size if cron falls behind.
 */
function aabenforms_core_cron(): void {
  $config = \Drupal::config('aabenforms_core.settings');
  $retention = (int) $config->get('audit.retention_days');
  if ($retention < 1) {
    return;
  }
  /** @var \Drupal\aabenforms_core\Service\AuditLogger $logger */
  $logger = \Drupal::service('aabenforms_core.audit_logger');
  $deleted = $logger->purge($retention);
  if ($deleted > 0) {
    \Drupal::logger('aabenforms_core')->info(
      'Audit log purge removed @count entries older than @days days.',
      ['@count' => $deleted, '@days' => $retention]
    );
  }
}
