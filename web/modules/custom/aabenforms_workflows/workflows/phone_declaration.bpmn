<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_phone_declaration"
                  targetNamespace="http://aabenforms.dk/bpmn"
                  exporter="AabenForms"
                  exporterVersion="1.0">

  <bpmn:process id="phone_declaration_process" name="Private Phone Use Declaration" isExecutable="true">
    <bpmn:documentation>[category: hr_internal]
Employee declares private use of an employer-paid mobile phone. Line
manager approves. Record is archived for audit. Pattern A
(single-approval). Based on the Ballerup Kommune pattern that replaced
a paper flow and saved an estimated 185+ hours per year.

<parameters>
  <parameter id="manager_email" label="Manager Email" type="email" required="true">
    <description>Line manager who approves the declaration</description>
  </parameter>
  <parameter id="tax_year" label="Tax Year" type="string" required="true">
    <description>Declaration year for archival</description>
  </parameter>
</parameters></bpmn:documentation>

    <bpmn:startEvent id="StartEvent_EmployeeSubmit" name="Employee Submits Declaration">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_RecordDeclaration" name="Record Declaration">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="Task_ManagerApprove" name="Manager Approves Declaration">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_Archive" name="Archive Declaration">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Archived" name="Declaration Archived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_EmployeeSubmit" targetRef="Task_RecordDeclaration"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_RecordDeclaration" targetRef="Task_ManagerApprove"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ManagerApprove" targetRef="Task_Archive"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Archive" targetRef="EndEvent_Archived"/>
  </bpmn:process>

</bpmn:definitions>
