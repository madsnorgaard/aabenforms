# Database
DB_NAME=aabenforms
DB_USER=aabenforms
DB_PASS=CHANGE_ME
DB_HOST=aabenforms_db
DB_PORT=3306

# Drupal
HASH_SALT=CHANGE_ME_GENERATE_RANDOM_STRING
TRUSTED_HOST_PATTERNS=api\.aabenforms\.dk

# Redis
REDIS_HOST=aabenforms_redis

# SMTP (mail delivery)
SMTP_HOST=mail.madsnorgaard.net
SMTP_PORT=587
SMTP_PROTOCOL=tls
SMTP_USER=mads@madsnorgaard.net
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=mads@madsnorgaard.net

# Address autocomplete (Klimadatastyrelsen Adressevælger).
# Token is an arbitrary >=10-char identifier today; use our own unique value
# (NOT the shared demo token "adressevaelger123") to avoid rate-limiting.
# Same value should be set as NUXT_ADRESSEVAELGER_TOKEN on the frontend.
AABENFORMS_ADRESSEVAELGER_TOKEN=aabenforms-adr-2026
# AABENFORMS_ADRESSEVAELGER_API_URL=https://adressevaelger.dk
